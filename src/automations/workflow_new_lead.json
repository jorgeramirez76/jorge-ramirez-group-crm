{
  "name": "New Lead Intake",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "new-lead",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "a1b2c3d4-0001-4000-8000-000000000001",
      "name": "Webhook - New Lead",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [220, 300],
      "webhookId": "new-lead-intake"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:11434/api/chat",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'gemma4:31b', messages: [ { role: 'system', content: 'You are a real estate lead classification assistant. Given the lead source and data, classify the lead temperature as exactly one of: hot, warm, cold. Respond with ONLY the single word: hot, warm, or cold.' }, { role: 'user', content: 'Classify this lead:\\nName: ' + $json.body.name + '\\nEmail: ' + $json.body.email + '\\nPhone: ' + $json.body.phone + '\\nLead Type: ' + $json.body.lead_type + '\\nSource: ' + $json.body.source } ], stream: false }) }}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "a1b2c3d4-0001-4000-8000-000000000002",
      "name": "Ollama - Classify Lead",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "temp-extract",
              "name": "temperature",
              "value": "={{ $json.message.content.trim().toLowerCase() }}",
              "type": "string"
            },
            {
              "id": "lead-name",
              "name": "lead_name",
              "value": "={{ $('Webhook - New Lead').item.json.body.name }}",
              "type": "string"
            },
            {
              "id": "lead-email",
              "name": "lead_email",
              "value": "={{ $('Webhook - New Lead').item.json.body.email }}",
              "type": "string"
            },
            {
              "id": "lead-phone",
              "name": "lead_phone",
              "value": "={{ $('Webhook - New Lead').item.json.body.phone }}",
              "type": "string"
            },
            {
              "id": "lead-type",
              "name": "lead_type",
              "value": "={{ $('Webhook - New Lead').item.json.body.lead_type }}",
              "type": "string"
            },
            {
              "id": "lead-source",
              "name": "lead_source",
              "value": "={{ $('Webhook - New Lead').item.json.body.source }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "a1b2c3d4-0001-4000-8000-000000000003",
      "name": "Set - Extract Temperature",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [700, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "hot-check",
              "leftValue": "={{ $json.temperature }}",
              "rightValue": "hot",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "a1b2c3d4-0001-4000-8000-000000000004",
      "name": "IF - Hot Lead",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [940, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8100/api/sms/send",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ to: $json.lead_phone, message: 'Hi ' + $json.lead_name + '! This is Teddy from George Ramirez\\'s real estate team. Thanks for reaching out! George is one of the top agents in the area and we\\'d love to help you. Are you available for a quick call in the next 15 minutes?' }) }}",
        "options": {}
      },
