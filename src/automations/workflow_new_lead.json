      "typeVersion": 4.2,
      "position": [1200, 160]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8200/api/email/send",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ to: $json.lead_email, subject: 'Welcome! George Ramirez Real Estate Team', body: 'Hi ' + $json.lead_name + ',\\n\\nThank you for your interest! I\\'m Teddy, George Ramirez\\'s assistant. George is excited to help you with your ' + $json.lead_type + ' needs.\\n\\nAs a hot lead, we\\'re prioritizing your request. Expect a call from George within the next 15 minutes.\\n\\nIn the meantime, feel free to reply to this email with any questions.\\n\\nBest,\\nTeddy\\nGeorge Ramirez Real Estate Team' }) }}",
        "options": {}
      },
      "id": "a1b2c3d4-0001-4000-8000-000000000006",
