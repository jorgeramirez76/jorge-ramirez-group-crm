        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ to: $json.lead_email, subject: 'Thanks for Your Interest - George Ramirez Real Estate', body: 'Hi ' + $json.lead_name + ',\\n\\nThank you for reaching out! I\\'m Teddy, George Ramirez\\'s assistant.\\n\\nWe received your inquiry about ' + $json.lead_type + ' and would love to help. George has deep expertise in the local market and is ready to assist when you are.\\n\\nFeel free to reply to this email or give us a call anytime.\\n\\nBest,\\nTeddy\\nGeorge Ramirez Real Estate Team' }) }}",
        "options": {}
      },
      "id": "a1b2c3d4-0001-4000-8000-000000000008",
      "name": "Email - Warm/Cold Lead",
